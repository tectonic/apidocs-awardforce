#!/usr/bin/env bash

set -euo pipefail

# Resolve the repo root from the script location so the helper works even when
# invoked via PATH or from another working directory.
ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_NAME="${0##*/}"
cd "$ROOT_DIR"

BOLD=""
YELLOW=""
RED=""
NC=""

if test -t 1; then
  ncolors=$(tput colors 2>/dev/null || true)

  if test -n "$ncolors" && test "$ncolors" -ge 8; then
    BOLD="$(tput bold)"
    YELLOW="$(tput setaf 3)"
    RED="$(tput setaf 1)"
    NC="$(tput sgr0)"
  fi
fi

# Derive the host user/group identity once so every docs-managed Compose command
# builds containers with the calling developer's UID/GID by default. Allow
# explicit HOST_* overrides for unusual local setups.
HOST_USER="${HOST_USER:-$(id -un)}"
HOST_UID="${HOST_UID:-$(id -u)}"
HOST_GID="${HOST_GID:-$(id -g)}"
export HOST_USER HOST_UID HOST_GID

# Select the available Docker Compose command once during script startup.
if docker compose &>/dev/null; then
  DOCKER_COMPOSE=(docker compose)
else
  DOCKER_COMPOSE=(docker-compose)
fi

# Canonical vertical slugs used when a command should target every docs site.
VERTICALS=(awardforce goodgrants)

# Display the available commands and example invocations.
usage() {
  cat <<'EOF'
Usage:
EOF

  cat <<EOF
  ${SCRIPT_NAME} awardforce [docker compose up options]
  ${SCRIPT_NAME} goodgrants [docker compose up options]
  ${SCRIPT_NAME} all [docker compose up options]
  ${SCRIPT_NAME} logs <awardforce|af|goodgrants|gg> [docker compose logs options]
  ${SCRIPT_NAME} validate [awardforce|af|goodgrants|gg|all]
  ${SCRIPT_NAME} openapi [awardforce|af|goodgrants|gg|all]
  ${SCRIPT_NAME} openapi-lint [awardforce|af|goodgrants|gg|all]
  ${SCRIPT_NAME} openapi-clean [awardforce|af|goodgrants|gg|all]
  ${SCRIPT_NAME} check
  ${SCRIPT_NAME} build [docker compose build options]
  ${SCRIPT_NAME} down [docker compose down options]
  ${SCRIPT_NAME} ps
  ${SCRIPT_NAME} npm <npm args...>

Examples:
  ${SCRIPT_NAME} awardforce
  ${SCRIPT_NAME} af
  ${SCRIPT_NAME} goodgrants -d
  ${SCRIPT_NAME} logs gg --tail=50
  ${SCRIPT_NAME} all --remove-orphans
  ${SCRIPT_NAME} validate
  ${SCRIPT_NAME} validate gg
  ${SCRIPT_NAME} openapi
  ${SCRIPT_NAME} openapi af
  ${SCRIPT_NAME} openapi-lint
  ${SCRIPT_NAME} openapi-lint gg
  ${SCRIPT_NAME} openapi-clean
  ${SCRIPT_NAME} openapi-clean gg
  ${SCRIPT_NAME} check
  ${SCRIPT_NAME} npm install
EOF
}

# Print a usage error for a specific command form and exit.
die_usage() {
  echo "${BOLD}${YELLOW}Usage:${NC} ${SCRIPT_NAME} $1" >&2
  exit 1
}

# Print a formatted error message and exit.
die() {
  echo "${BOLD}${RED}Error:${NC} $1" >&2
  exit 1
}

# Print an unknown-command error, then show help and exit.
die_unknown_command() {
  echo "${BOLD}${RED}Error:${NC} Unknown command: $1" >&2
  usage >&2
  exit 1
}

# Ensure the local Docker daemon is available before running Compose commands.
ensure_docker_available() {
  if ! docker info > /dev/null 2>&1; then
    echo "${BOLD}${RED}Docker is not running.${NC}" >&2
    echo "${YELLOW}Please start Docker and try again.${NC}" >&2
    echo "  - ${BOLD}${YELLOW}macOS:${NC} Open Docker Desktop" >&2
    echo "  - ${BOLD}${YELLOW}Linux:${NC} sudo systemctl start docker" >&2
    exit 1
  fi
}

# Run the selected Docker Compose command after the Docker preflight check.
docker_compose() {
  ensure_docker_available
  "${DOCKER_COMPOSE[@]}" "$@"
}

# Run the Mint CLI inside the selected vertical service container.
run_mint_vertical() {
  local vertical="$1"
  shift
  docker_compose run --rm --entrypoint /docs/node_modules/.bin/mint "$vertical" "$@"
}

# Run a shell script inside the selected vertical service for Redocly tasks.
run_redocly_vertical() {
  local vertical="$1"
  local script="$2"
  shift
  shift
  docker_compose run --rm \
    --entrypoint sh "$vertical" -lc "$script" sh "$@" </dev/null
}

# Require a vertical argument for commands that target one docs site.
require_vertical() {
  local vertical="${1:-}"
  local usage_text="$2"

  if [[ -z "$vertical" ]]; then
    die_usage "$usage_text"
  fi
}

# Run a helper for one canonical vertical or for every vertical.
run_for_target() {
  local target="$1"
  local usage_text="$2"
  local handler="$3"
  shift 3

  case "$target" in
    all)
      for vertical in "${VERTICALS[@]}"; do
        "$handler" "$vertical" "$@"
      done
      ;;
    awardforce|af|goodgrants|gg)
      "$handler" "$(vertical_name "$target")" "$@"
      ;;
    *)
      die_usage "$usage_text"
      ;;
  esac
}

# Reject unexpected trailing arguments for fixed-shape commands.
require_no_extra_args() {
  local usage_text="$1"
  local arg_count="$2"

  if [[ "$arg_count" -gt 0 ]]; then
    die_usage "$usage_text"
  fi
}

# Canonicalize user-facing vertical aliases to a single slug that can be reused
# for both Docker service names and on-disk docs directory names.
vertical_name() {
  case "${1:-}" in
    awardforce|af) echo "awardforce" ;;
    goodgrants|gg) echo "goodgrants" ;;
    *)
      die "Unknown vertical: ${1:-}"
      ;;
  esac
}

# Docs directories follow the convention <vertical>-docs/.
vertical_dir() {
  printf '%s-docs\n' "$(vertical_name "$1")"
}

# Bundle every versioned OpenAPI source for one vertical into api-reference/.
bundle_openapi_vertical() {
  local vertical="$1"
  local vertical_path
  local src_root
  local -a version_dirs=()

  vertical_path="$(vertical_dir "$vertical")"
  src_root="$ROOT_DIR/$vertical_path/src"

  if [[ ! -d "$src_root" ]]; then
    die "Missing source directory: ${vertical_path}/src"
  fi

  # Collect all versioned source specs up front. Running docker compose inside a
  # while-read loop can consume the loop stdin and stop after the first match.
  mapfile -t version_dirs < <(find "$src_root" -mindepth 2 -maxdepth 2 -type f -name 'openapi.yaml' | sort | while read -r spec_path; do basename "$(dirname "$spec_path")"; done)

  if [[ "${#version_dirs[@]}" -eq 0 ]]; then
    die "No versioned OpenAPI sources found under ${vertical_path}/src"
  fi

  run_redocly_vertical "$vertical" '
    for version_dir in "$@"; do
      input_path="src/${version_dir}/openapi.yaml"
      output_path="api-reference/openapi-${version_dir}.yaml"
      /docs/node_modules/.bin/redocly bundle "$input_path" --output "$output_path"
    done
  ' "${version_dirs[@]}"
}

# Lint generated bundled OpenAPI files for one vertical.
lint_openapi_vertical() {
  local vertical="$1"
  local vertical_path
  local output_root
  local -a bundled_files=()

  vertical_path="$(vertical_dir "$vertical")"
  output_root="$ROOT_DIR/$vertical_path/api-reference"

  if [[ ! -d "$output_root" ]]; then
    die "Missing api-reference directory: ${vertical_path}/api-reference"
  fi

  mapfile -t bundled_files < <(find "$output_root" -maxdepth 1 -type f -name 'openapi-*.yaml' | sort | while read -r bundled_path; do basename "$bundled_path"; done)

  if [[ "${#bundled_files[@]}" -eq 0 ]]; then
    die "No bundled OpenAPI files found under ${vertical_path}/api-reference. Run '${SCRIPT_NAME} openapi ${vertical}' first."
  fi

  run_redocly_vertical "$vertical" '
    for bundled_file in "$@"; do
      /docs/node_modules/.bin/redocly lint "api-reference/${bundled_file}"
    done
  ' "${bundled_files[@]}"
}

# Remove generated bundled OpenAPI files for one vertical.
clear_bundled_openapi_vertical() {
  local vertical="$1"
  local vertical_path
  local output_root
  local -a bundled_paths=()

  vertical_path="$(vertical_dir "$vertical")"
  output_root="$ROOT_DIR/$vertical_path/api-reference"

  if [[ ! -d "$output_root" ]]; then
    die "Missing api-reference directory: ${vertical_path}/api-reference"
  fi

  mapfile -t bundled_paths < <(find "$output_root" -maxdepth 1 -type f -name 'openapi-*.yaml' | sort)

  if [[ "${#bundled_paths[@]}" -eq 0 ]]; then
    echo "No bundled OpenAPI files found under ${vertical_path}/api-reference"
    return
  fi

  rm -f "${bundled_paths[@]}"
  echo "Removed ${#bundled_paths[@]} bundled OpenAPI file(s) from ${vertical_path}/api-reference"
}

# Run the full docs quality gate used by the pre-push hook as a manual command.
check_docs_pipeline() {
  local strict_lint="${DOCS_HOOK_STRICT_LINT:-0}"
  local -a bundle_paths=(
    awardforce-docs/api-reference
    goodgrants-docs/api-reference
  )

  echo "docs(check): regenerating bundled OpenAPI specs"
  run_for_target all "check" bundle_openapi_vertical

  if ! git diff --quiet -- "${bundle_paths[@]}"; then
    echo "docs(check): bundled OpenAPI specs changed during regeneration." >&2
    echo "Run '${SCRIPT_NAME} openapi', review the updated api-reference/openapi-*.yaml files, and commit them before continuing." >&2
    git status --short -- "${bundle_paths[@]}" >&2
    exit 1
  fi

  echo "docs(check): validating Mintlify docs builds"
  run_for_target all "check" run_mint_vertical validate

  echo "docs(check): linting bundled OpenAPI specs"
  if ! run_for_target all "check" lint_openapi_vertical; then
    if [[ "$strict_lint" == "1" ]]; then
      echo "docs(check): Redocly lint failed and strict lint is enabled." >&2
      exit 1
    fi

    echo "docs(check): Redocly lint is currently advisory because the existing bundled specs still have known lint failures." >&2
  fi
}

command="${1:-help}"
shift || true

case "$command" in
  all|up)
    docker_compose up "$@"
    ;;
  logs)
    vertical="${1:-}"
    require_vertical "$vertical" "logs <awardforce|af|goodgrants|gg> [docker compose logs options]"
    shift
    docker_compose logs "$@" "$(vertical_name "$vertical")"
    ;;
  validate)
    target="${1:-all}"
    shift || true
    require_no_extra_args "validate [awardforce|af|goodgrants|gg|all]" "$#"
    run_for_target "$target" "validate [awardforce|af|goodgrants|gg|all]" run_mint_vertical validate
    ;;
  openapi)
    target="${1:-all}"
    shift || true
    require_no_extra_args "openapi [awardforce|af|goodgrants|gg|all]" "$#"
    run_for_target "$target" "openapi [awardforce|af|goodgrants|gg|all]" bundle_openapi_vertical
    ;;
  openapi-lint)
    target="${1:-all}"
    shift || true
    require_no_extra_args "openapi-lint [awardforce|af|goodgrants|gg|all]" "$#"
    run_for_target "$target" "openapi-lint [awardforce|af|goodgrants|gg|all]" lint_openapi_vertical
    ;;
  openapi-clean)
    target="${1:-all}"
    shift || true
    require_no_extra_args "openapi-clean [awardforce|af|goodgrants|gg|all]" "$#"
    run_for_target "$target" "openapi-clean [awardforce|af|goodgrants|gg|all]" clear_bundled_openapi_vertical
    ;;
  check)
    require_no_extra_args "check" "$#"
    check_docs_pipeline
    ;;
  awardforce|af|goodgrants|gg)
    docker_compose up "$@" "$(vertical_name "$command")"
    ;;
  build)
    docker_compose build "$@"
    ;;
  down)
    docker_compose down "$@"
    ;;
  ps)
    docker_compose ps
    ;;
  npm)
    docker_compose run --rm npm "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    die_unknown_command "$command"
    ;;
esac