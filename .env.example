# Optional Mint dev server port overrides.
MINT_PORT_AWARDFORCE=3000
MINT_PORT_GOODGRANTS=3001

# If you run raw `docker compose` commands instead of `./docs`, you can also
# define these host identity values manually:
# HOST_USER=youruser
# HOST_UID=youruid
# HOST_GID=yourgid

# Target API for `./docs schemathesis` (defaults to https://api.cr4ce.com).
# Point this at a staging/test host to avoid fuzzing production.
# AWARDFORCE_API_URL=https://api.cr4ce.com

# Award Force API key used by `./docs schemathesis`. Keep this in .env only;
# it is injected as the `x-api-key` header and never committed.
# AWARDFORCE_API_KEY=your-api-key
