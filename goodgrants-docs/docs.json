{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Good Grants",
  "colors": {
    "primary": "#17154B",
    "light": "#eb3700",
    "dark": "#2741F1"
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "decoration": "gradient"
  },
"fonts": {
    "heading": {
      "family": "Montserrat",
      "format": "woff2",
      "weight": 400,
      "source": "https://fonts.wp.com/s/opensans/v44/memvYaGs126MiZpBA-UvWbX2vVnXBbObj2OVTS-muw.woff2"
    },
    "body": {
      "family": "Montserrat",
      "format": "woff2",
      "weight": 400,
      "source": "https://fonts.wp.com/s/opensans/v44/memvYaGs126MiZpBA-UvWbX2vVnXBbObj2OVTS-muw.woff2"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Getting started",
        "pages": [
          {
            "group": "Getting started",
            "pages": [
              "/pages/intro",
              "/pages/authentication",
              "/pages/requests",
              "/pages/responses",
              "/pages/webhooks",
              "/pages/versioning"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      },
      {
        "tab": "Changelog",
        "pages": ["/pages/changelog"]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Help Center",
          "href": "https://PLACEHOLDER",
          "icon": "headset"
        },
        {
          "anchor": "Status",
          "href": "https://PLACEHOLDER",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://goodgrants.com"
  },
  "navbar": {
    "links": []
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://PLACEHOLDER",
      "facebook": "https://PLACEHOLDER",
      "linkedin": "https://PLACEHOLDER"
    }
  }
}
